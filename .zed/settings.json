{
	"format_on_save": "on",
	"formatter": "language_server",
	"auto_indent_on_paste": true,
	"languages": {
		"Astro": {
			"formatter": {
				"language_server": {
					"name": "biome"
				}
			},
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			},
			"language_servers": [
				"eslint",
				"..."
			]
		},
		"CSS": {
			"language_servers": [
				"tailwindcss-intellisense-css",
				"!vscode-css-language-server",
				"..."
			]
		},
		"JSON": {
			"formatter": {
				"language_server": {
					"name": "biome"
				}
			}
		},
		"JSONC": {
			"formatter": {
				"language_server": {
					"name": "biome"
				}
			}
		},
		"JavaScript": {
			"formatter": [
				{
					"language_server": {
						"name": "biome"
					}
				},
				{
					"code_action": "source.fixAll.biome"
				},
				{
					"code_action": "source.organizeImports.biome"
				}
			]
		},
		"TypeScript": {
			"formatter": [
				{
					"language_server": {
						"name": "biome"
					}
				},
				{
					"code_action": "source.fixAll.biome"
				},
				{
					"code_action": "source.organizeImports.biome"
				}
			]
		}
	},
	"lsp": {
		"biome": {
			"settings": {
				"require_config_file": true
			}
		},
		"tailwindcss-language-server": {
			"settings": {
				"includeLanguages": {
					"astro": "html"
				},
				"experimental": {
					"classRegex": [
						"class=\"([^\"]*)\"",
						"class='([^']*)'",
						"class:list=\"{([^}]*)}\"",
						"class:list='{([^}]*)}'"
					]
				}
			}
		}
	}
}
