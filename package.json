{
	"name": "renovabit",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"@base-ui/react": "^1.5.0",
			"@biomejs/biome": "2.4.15",
			"@hugeicons/core-free-icons": "^4.1.4",
			"@hugeicons/react": "^1.1.6",
			"@tailwindcss/vite": "^4.1.18",
			"@types/react": "^19.2.2",
			"@types/react-dom": "^19.2.2",
			"better-auth": "^1.6.11",
			"better-themes": "^1.1.0",
			"bun-types": "^1.3.10",
			"class-variance-authority": "^0.7.1",
			"drizzle-orm": "0.42.0",
			"nanoid": "5.1.6",
			"prettier": "^3.8.3",
			"prettier-plugin-astro": "^0.14.1",
			"react": "^19.2.0",
			"react-dom": "^19.2.0",
			"serialize-error": "13.0.1",
			"slugify": "^1.6.9",
			"sonner": "^2.0.7",
			"typescript": "6.0.3"
		}
	},
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"check": "biome check . --write && cd apps/landing && bun run check",
		"check:biome": "biome check . --write",
		"check-types": "turbo run check-types",
		"clean": "bun run clean:turbo && bun run clean:dist",
		"clean:all": "bun run clean && bun run clean:node_modules",
		"clean:turbo": "find . -path ./docker-volumes -prune -o -name \".turbo\" -type d -prune -exec rm -rf {} +",
		"clean:dist": "find . -path ./docker-volumes -prune -o -name \"dist\" -type d -prune -exec rm -rf {} +",
		"clean:node_modules": "find . -path ./docker-volumes -prune -o -name \"node_modules\" -type d -prune -exec rm -rf {} +"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@commitlint/cli": "^21.0.1",
		"@commitlint/config-conventional": "^21.0.1",
		"@renovabit/biome-config": "*",
		"@renovabit/ts-config": "*",
		"lefthook": "^2.1.6",
		"prettier": "catalog:",
		"prettier-plugin-astro": "catalog:",
		"turbo": "^2.9.14",
		"typescript": "catalog:"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.10"
}
