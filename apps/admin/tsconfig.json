{
	"extends": "@renovabit/ts-config/base",
	"compilerOptions": {
		"jsx": "react-jsx",
		"types": [
			"vite/client",
			"bun-types"
		],
		"paths": {
			"@/*": [
				"./src/*",
				"../../apps/api/src/*"
			],
			"@renovabit/ui/*": [
				"../../packages/ui/src/*"
			],
			"@renovabit/backend-client": [
				"../../packages/backend-client/src/index.ts"
			],
			"@renovabit/api": [
				"../../apps/api/src/index.ts"
			],
			"@renovabit/*": [
				"../../packages/*"
			]
		}
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx"
	]
}
