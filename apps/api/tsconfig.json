{
	"extends": "@renovabit/ts-config/base",
	"compilerOptions": {
		"lib": ["ES2022"],
		"types": ["bun-types"],
		"rootDir": "./src",
		"outDir": "./dist",
		"paths": {
			"@/*": ["./src/*"],
			"@renovabit/*": [
				"../../packages/*"
			]
		}
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
