		"@loglayer/elysia": "^2.1.0",
		"@loglayer/transport-simple-pretty-terminal": "^3.0.2",
		"@renovabit/backend-errors": "*",
		"@renovabit/db": "*",
		"@sinclair/typebox": "^0.34.49",
		"better-auth": "catalog:",
		"drizzle-orm": "catalog:",
		"drizzle-typebox": "^0.3.3",
		"elysia": "^1.4.28",
		"loglayer": "^9.1.0",
		"nanoid": "catalog:",
		"serialize-error": "catalog:",
		"slugify": "catalog:"
